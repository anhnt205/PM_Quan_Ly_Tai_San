				{
					"name": "1. Get KyTaiLieu by TaiLieu ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/chuky/{{idTaiLieu}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"chuky",
								"{{idTaiLieu}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "2. Create/Update KyTaiLieu List",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "[\n    {\n        \"id\": \"ktl001\",\n        \"idTaiLieu\": \"{{idTaiLieu}}\",\n        \"loaiKy\": 1,\n        \"x\": 100.5,\n        \"y\": 200.3,\n        \"idNguoiKy\": \"nk001\",\n        \"chuKySo\": \"base64_encoded_signature\",\n        \"ngayKy\": \"2024-01-15 10:30:00\",\n        \"stt\": 1\n    },\n    {\n        \"id\": \"ktl002\",\n        \"idTaiLieu\": \"{{idTaiLieu}}\",\n        \"loaiKy\": 2,\n        \"x\": 300.5,\n        \"y\": 400.3,\n        \"idNguoiKy\": \"nk002\",\n        \"chuKySo\": \"base64_encoded_signature_2\",\n        \"ngayKy\": \"2024-01-15 11:30:00\",\n        \"stt\": 2\n    }\n]"
						},
						"url": {
							"raw": "{{baseUrl}}/api/chuky",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"chuky"
							]
						}
					},
					"response": []
				},
				{
					"name": "3. Delete KyTaiLieu by ID",
