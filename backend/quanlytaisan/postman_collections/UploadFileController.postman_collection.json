{
  "info": {
    "name": "UploadFileController",
    "description": "API collection for File Upload/Download management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Upload File",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "path/to/file.pdf"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/upload",
          "host": ["{{base_url}}"],
          "path": ["api", "upload"]
        }
      },
      "response": []
    },
    {
      "name": "Download File",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/upload/download/{{fileName}}",
          "host": ["{{base_url}}"],
          "path": ["api", "upload", "download", "{{fileName}}"],
          "variable": [
            {
              "key": "fileName",
              "value": "example.pdf"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Preview File",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/upload/preview/{{fileName}}",
          "host": ["{{base_url}}"],
          "path": ["api", "upload", "preview", "{{fileName}}"],
          "variable": [
            {
              "key": "fileName",
              "value": "example.pdf"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Export to Excel",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"id\": \"1\",\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"age\": 30,\n    \"active\": true\n  },\n  {\n    \"id\": \"2\",\n    \"name\": \"Jane Smith\",\n    \"email\": \"jane@example.com\",\n    \"age\": 25,\n    \"active\": false\n  }\n]"
        },
        "url": {
          "raw": "{{base_url}}/api/upload/export?sheetName={{sheetName}}",
          "host": ["{{base_url}}"],
          "path": ["api", "upload", "export"],
          "query": [
            {
              "key": "sheetName",
              "value": "{{sheetName}}",
              "description": "Tên sheet trong file Excel"
            }
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "fileName",
      "value": "example.pdf"
    },
    {
      "key": "sheetName",
      "value": "Data"
    }
  ]
}
