{
  "info": {
    "name": "BaoCaoController",
    "description": "API collection for BaoCao management - Báo cáo điều động tài sản, kiểm kê tài sản và CCDC",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Bao Cao Dieu Dong Tai San",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/baocao/dieudongtaisan?idcongty={{idcongty}}&loai={{loai}}",
          "host": ["{{base_url}}"],
          "path": ["api", "baocao", "dieudongtaisan"],
          "query": [
            {
              "key": "idcongty",
              "value": "{{idcongty}}",
              "description": "ID của công ty"
            },
            {
              "key": "loai",
              "value": "{{loai}}",
              "description": "Loại báo cáo (1: Tài sản, 2: CCDC)"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Bao Cao Kiem Ke Tai San",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/baocao/baocaokiemketaisan?iddonvi={{iddonvi}}&ngayBanGiao={{ngayBanGiao}}",
          "host": ["{{base_url}}"],
          "path": ["api", "baocao", "baocaokiemketaisan"],
          "query": [
            {
              "key": "iddonvi",
              "value": "{{iddonvi}}",
              "description": "ID của đơn vị"
            },
            {
              "key": "ngayBanGiao",
              "value": "{{ngayBanGiao}}",
              "description": "Ngày bàn giao (format: yyyy-MM-dd)"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Bao Cao Kiem Ke CCDC",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/baocao/baocaokiemkeccdc?iddonvi={{iddonvi}}&ngayBanGiao={{ngayBanGiao}}",
          "host": ["{{base_url}}"],
          "path": ["api", "baocao", "baocaokiemkeccdc"],
          "query": [
            {
              "key": "iddonvi",
              "value": "{{iddonvi}}",
              "description": "ID của đơn vị"
            },
            {
              "key": "ngayBanGiao",
              "value": "{{ngayBanGiao}}",
              "description": "Ngày bàn giao (format: yyyy-MM-dd)"
            }
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "description": "Base URL của API server"
    },
    {
      "key": "idcongty",
      "value": "1",
      "description": "ID của công ty mặc định"
    },
    {
      "key": "iddonvi",
      "value": "1",
      "description": "ID của đơn vị mặc định"
    },
    {
      "key": "loai",
      "value": "1",
      "description": "Loại báo cáo mặc định (1: Tài sản, 2: CCDC)"
    },
    {
      "key": "ngayBanGiao",
      "value": "2024-01-01",
      "description": "Ngày bàn giao mặc định"
    }
  ]
}
