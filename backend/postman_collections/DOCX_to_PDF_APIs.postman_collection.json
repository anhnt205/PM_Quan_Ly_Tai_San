{
	"info": {
		"_postman_id": "docx-to-pdf-apis",
		"name": "DOCX to PDF Conversion APIs",
		"description": "Collection chứa các API upload file DOCX và convert sang PDF",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Upload File",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"type": "file",
							"src": []
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/upload",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"upload"
					]
				}
			},
			"response": []
		},
		{
			"name": "Download File",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/upload/download/{{file_name}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"upload",
						"download",
						"{{file_name}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Preview File",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/upload/preview/{{file_name}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"upload",
						"preview",
						"{{file_name}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Convert DOCX to PDF (Download)",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"type": "file",
							"src": []
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/upload/docx-to-pdf",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"upload",
						"docx-to-pdf"
					]
				}
			},
			"response": []
		},
		{
			"name": "Convert DOCX to PDF (Return Bytes)",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"type": "file",
							"src": []
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/upload/docx-to-pdf-bytes",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"upload",
						"docx-to-pdf-bytes"
					]
				}
			},
			"response": []
		},
		{
			"name": "Export JSON to Excel",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "[\n    {\n        \"id\": \"1\",\n        \"name\": \"Nguyễn Văn A\",\n        \"age\": 25,\n        \"department\": \"IT\"\n    },\n    {\n        \"id\": \"2\",\n        \"name\": \"Trần Thị B\",\n        \"age\": 30,\n        \"department\": \"HR\"\n    }\n]"
				},
				"url": {
					"raw": "{{base_url}}/api/upload/export?sheetName=Employees",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"upload",
						"export"
					],
					"query": [
						{
							"key": "sheetName",
							"value": "Employees"
						}
					]
				}
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "file_name",
			"value": "example.docx",
			"type": "string"
		}
	]
}
